<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose-based activity uses the platform Material theme as a parent so
         we don't need androidx.appcompat. Compose handles its own theming. -->
    <style name="Theme.BMUAttendance" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
